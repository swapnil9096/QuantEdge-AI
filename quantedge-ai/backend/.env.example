# QuantEdge AI — backend credentials
# Copy this to backend/.env and fill in your keys. Never commit backend/.env.

# --- Market data (used by AlphaScan / tab 5) ---
TWELVEDATA_API_KEY=
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=

# --- OpenAI (GPT-4o narrative on AlphaScan) ---
OPENAI_API_KEY=

# --- Claude access (used by Scanner / Backtest / ML / AI Insights tabs) ---
# Pick ONE of the three setups below. Leave the others empty.
#
# 1) Portkey VIRTUAL-KEY mode (Portkey stores your Anthropic key):
#    PORTKEY_API_KEY=pk-xxx
#    PORTKEY_VIRTUAL_KEY=anthropic-vk-xxx
#
# 2) Portkey PASS-THROUGH mode (you still keep your own Anthropic key):
#    PORTKEY_API_KEY=pk-xxx
#    ANTHROPIC_API_KEY=sk-ant-api03-xxx
#
# 3) Direct Anthropic (no gateway):
#    ANTHROPIC_API_KEY=sk-ant-api03-xxx

PORTKEY_API_KEY=
PORTKEY_VIRTUAL_KEY=
PORTKEY_CONFIG=

ANTHROPIC_API_KEY=
AUTO_TRADE_MARKET_OPEN_ONLY=true
# Optional overrides
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# PORTKEY_BASE_URL=https://api.portkey.ai/v1

# --- Telegram alerts ---
# TELEGRAM_BOT_TOKEN is a secret → goes in the vault, not here:
#   python scripts/setup_secrets.py --add-secret TELEGRAM_BOT_TOKEN=<token>
# TELEGRAM_CHAT_ID is not secret on its own → keep it here:
TELEGRAM_CHAT_ID=
