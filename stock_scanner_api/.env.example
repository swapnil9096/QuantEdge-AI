APP_NAME=stock-scanner-api
APP_ENV=production
LOG_LEVEL=INFO
API_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/stock_scanner
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=300

SCAN_INTERVAL_MINUTES=5
HIGH_CONFIDENCE_THRESHOLD=80
MIDCAP_THRESHOLD=5000000000
PROMOTER_HOLDING_MIN=45
UNIVERSE_SYMBOLS=RELIANCE,TCS,INFY,HDFCBANK,ICICIBANK,LT,SBIN,ITC,BHARTIARTL,AXISBANK

ALPHA_VANTAGE_API_KEY=
TWELVEDATA_API_KEY=
POLYGON_API_KEY=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
